{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <div class="flex flex-1 items-center justify-center min-h-[80vh] py-10">
        <div class="w-full max-w-md">
            {# --- Carte façon Poké Ball --- #}
            <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-200">
                {# Moitié haute rouge + cercle central #}
                <div class="relative bg-red-600 h-28">
                    <div class="absolute left-1/2 -bottom-8 -translate-x-1/2 w-16 h-16 rounded-full bg-white border-[6px] border-gray-900 shadow-md flex items-center justify-center">
                        <div class="w-5 h-5 rounded-full bg-gray-900"></div>
                    </div>
                    <div class="absolute inset-x-0 bottom-0 h-1.5 bg-gray-900"></div>
                </div>

                <div class="px-8 pt-12 pb-8">
                    <h1 class="font-poke outline-font-poke text-yellow-300 text-3xl text-center mb-1">Locamon</h1>
                    <p class="text-center text-gray-500 mb-8">Connecte-toi pour louer tes Pokémon</p>

                    {% if error %}
                        <div class="mb-6 flex items-start gap-2 px-4 py-3 rounded-xl bg-red-50 border border-red-200 text-red-800 text-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10A8 8 0 1 1 2 10a8 8 0 0 1 16 0Zm-7 4a1 1 0 1 1-2 0 1 1 0 0 1 2 0Zm-1-9a1 1 0 0 0-1 1v4a1 1 0 1 0 2 0V6a1 1 0 0 0-1-1Z" clip-rule="evenodd"/></svg>
                            <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                        </div>
                    {% endif %}

                    <form action="{{ path('user.login') }}" method="post" class="space-y-5">
                        <div>
                            <label for="username" class="block text-sm font-semibold text-gray-700 mb-1.5">Identifiant</label>
                            <input type="text" id="username" name="_username" value="{{ last_username }}" required autofocus
                                   autocomplete="username"
                                   class="w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:border-red-500 focus:ring-2 focus:ring-red-200 outline-none transition">
                        </div>

                        <div>
                            <label for="password" class="block text-sm font-semibold text-gray-700 mb-1.5">Mot de passe</label>
                            <input type="password" id="password" name="_password" required
                                   autocomplete="current-password"
                                   class="w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:border-red-500 focus:ring-2 focus:ring-red-200 outline-none transition">
                        </div>

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                        <button type="submit"
                                class="w-full py-3 rounded-xl bg-red-600 text-white font-bold hover:bg-red-700 active:scale-[0.99] focus:ring-2 focus:ring-red-300 transition">
                            Se connecter
                        </button>
                    </form>

                    <p class="text-center text-sm text-gray-500 mt-6">
                        Pas encore de compte ?
                        <a href="{{ path('user.register') }}" class="font-semibold text-red-600 hover:text-red-700 underline-offset-2 hover:underline">Crée-en un</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
