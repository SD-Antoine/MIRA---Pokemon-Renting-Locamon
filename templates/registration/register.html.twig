{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% set field_classes = 'w-full px-4 py-2.5 rounded-xl border border-gray-300 focus:border-red-500 focus:ring-2 focus:ring-red-200 outline-none transition' %}

{% block body %}
    <div class="flex flex-1 items-center justify-center min-h-[80vh] py-10">
        <div class="w-full max-w-md">
            <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-200">
                {# En-tête Poké Ball #}
                <div class="relative bg-red-600 h-28">
                    <div class="absolute left-1/2 -bottom-8 -translate-x-1/2 w-16 h-16 rounded-full bg-white border-[6px] border-gray-900 shadow-md flex items-center justify-center">
                        <div class="w-5 h-5 rounded-full bg-gray-900"></div>
                    </div>
                    <div class="absolute inset-x-0 bottom-0 h-1.5 bg-gray-900"></div>
                </div>

                <div class="px-8 pt-12 pb-8">
                    <h1 class="font-poke outline-font-poke text-yellow-300 text-3xl text-center mb-1">Locamon</h1>
                    <p class="text-center text-gray-500 mb-8">Crée ton compte de dresseur</p>

                    {{ form_start(registrationForm, {'attr': {'class': 'space-y-5', 'novalidate': 'novalidate'}}) }}
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="{{ registrationForm.username.vars.id }}">Identifiant</label>
                            {{ form_widget(registrationForm.username, {'attr': {'class': field_classes, 'placeholder': 'Sacha'}}) }}
                            <div class="text-red-600 text-sm mt-1">{{ form_errors(registrationForm.username) }}</div>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="{{ registrationForm.mail.vars.id }}">Email <span class="text-gray-400 font-normal">(optionnel)</span></label>
                            {{ form_widget(registrationForm.mail, {'attr': {'class': field_classes, 'placeholder': 'sacha@bourg-palette.fr'}}) }}
                            <div class="text-red-600 text-sm mt-1">{{ form_errors(registrationForm.mail) }}</div>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="{{ registrationForm.plainPassword.first.vars.id }}">Mot de passe</label>
                            {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': field_classes}}) }}
                            <div class="text-red-600 text-sm mt-1">{{ form_errors(registrationForm.plainPassword.first) }}</div>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5" for="{{ registrationForm.plainPassword.second.vars.id }}">Confirme le mot de passe</label>
                            {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': field_classes}}) }}
                            <div class="text-red-600 text-sm mt-1">{{ form_errors(registrationForm.plainPassword.second) }}</div>
                        </div>

                        <button type="submit"
                                class="w-full py-3 rounded-xl bg-red-600 text-white font-bold hover:bg-red-700 active:scale-[0.99] focus:ring-2 focus:ring-red-300 transition">
                            Créer mon compte
                        </button>
                    {{ form_end(registrationForm) }}

                    <p class="text-center text-sm text-gray-500 mt-6">
                        Déjà un compte ?
                        <a href="{{ path('user.login') }}" class="font-semibold text-red-600 hover:text-red-700 underline-offset-2 hover:underline">Connecte-toi</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
